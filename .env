PG_HOST=postgres
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=postgres
DB_URL=postgresql://postgres:postgres@postgres:5432/postgres
PGDATA=/var/lib/postgresql/data/pgdata
MYPYPATH=/MBSNetwork/src/typings
ALIGNMENTS_DIR=/MBSNetwork/data/alignments
ANALYSIS_DIR=/MBSNetwork/data/analysis
FIGURES_DIR=/MBSNetwork/figures
NETWORKS_DIR=/MBSNetwork/data/networks
LOGS_DIR=/MBSNetwork/logs
STRUCTURES_DIR=/MBSNetwork/data/structures
LIGANDS=Zn,Co,Cu,Fe,Mn,Mo,Ni,V,W
ATOMS=65
RESOLUTION=3.0
UNIPROT_ONLY=False
REPRESENTATIVE_THRESHOLD=0.5
N_JOBS=11
LOSS_FUNCTION=tukey
MAX_CORRESPONDENCE_DISTANCE=1000.0
CONFIGURATION_PARAMETER=1.8
COARSE_ALIGNMENTS=200
MAX_COARSE_ITERATIONS=5
MAX_FINETUNE_ITERATIONS=30
TOP_RANKING_FRACTION=0.05
RMSD_IGNORE_THRESHOLD=0.1
LOG_DIVISOR=100
SAVE_DIVISOR=100
DEFAULT_BASE_URL=http://host.docker.internal:1234/v1
